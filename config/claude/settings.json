{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(cargo add *)",
      "Bash(cargo bench *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo deny *)",
      "Bash(cargo doc *)",
      "Bash(cargo fmt *)",
      "Bash(cargo init *)",
      "Bash(cargo install *)",
      "Bash(cargo nextest *)",
      "Bash(cargo remove *)",
      "Bash(cargo run *)",
      "Bash(cargo test *)",
      "Bash(cargo tree *)",
      "Bash(cargo update *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(curl *)",
      "Bash(date *)",
      "Bash(dig *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(docker build *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh api *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh label list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr create *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr list *)",
      "Bash(gh pr merge --auto --squash)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh search code *)",
      "Bash(gh search issues *)",
      "Bash(gh search prs *)",
      "Bash(gh search repos *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git restore *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git switch *)",
      "Bash(grep *)",
      "Bash(gws calendar events list *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mise *)",
      "Bash(mv *)",
      "Bash(nvim *)",
      "Bash(mkdir *)",
      "Bash(npm ci *)",
      "Bash(npm install *)",
      "Bash(npm list *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm run type-check *)",
      "Bash(npm test *)",
      "Bash(paplay *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm run build *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run test *)",
      "Bash(pnpm run type-check *)",
      "Bash(pnpm test *)",
      "Bash(pwd)",
      "Bash(sam validate *)",
      "Bash(sort *)",
      "Bash(stylua *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tmux *)",
      "Bash(tree *)",
      "Bash(uv add *)",
      "Bash(uv init *)",
      "Bash(uv pip list *)",
      "Bash(uv remove *)",
      "Bash(uv run mypy *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv sync *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "mcp__aws-knowledge",
      "mcp__context7",
      "mcp__playwright",
      "mcp__serena"
    ],
    "deny": [
      "Bash(gh api --method *)",
      "Bash(gh api * --method *)",
      "Bash(gh api -X *)",
      "Bash(gh api * -X *)",
      "Bash(gh api -f *)",
      "Bash(gh api * -f *)",
      "Bash(gh api -F *)",
      "Bash(gh api * -F *)",
      "Bash(gh api --raw-field *)",
      "Bash(gh api * --raw-field *)",
      "Bash(gh api --field *)",
      "Bash(gh api * --field *)",
      "Bash(gh api --input *)",
      "Bash(gh api * --input *)",
      "NotebookEdit",
      "NotebookRead"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify processing"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify permission"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify waiting_for_input"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify permission"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify waiting_for_input"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "Japanese",
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.config/gh/hosts.yml",
        "~/.env",
        "~/.gnupg",
        "~/.netrc",
        "~/.ssh"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "showTurnDuration": true
}
