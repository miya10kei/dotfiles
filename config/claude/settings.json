  "deniedMcpServers": [
    {
      "serverName": "claude_ai_AWS_Knowledge_MCP_Server"
    },
    {
      "serverName": "claude_ai_Context7"
    },
    {
      "serverName": "claude_ai_Atlassian"
    },
    {
      "serverName": "claude_ai_Slack"
    }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ccjanus --flexible-match"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "companyAnnouncements": [
    "個人契約のClaude Codeです"
  ],
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal",
  "showTurnDuration": true,
  "skipAutoPermissionPrompt": true,
  "effort": "high",
  "agentPushNotifEnabled": true,
  "tui": "fullscreen"
}
