{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(actionlint *)",
      "Bash(arch *)",
      "Bash(aws * batch-describe-* *)",
      "Bash(aws * batch-get-* *)",
      "Bash(aws * check-* *)",
      "Bash(aws * confirm-* *)",
      "Bash(aws * describe-* *)",
      "Bash(aws * detect-* *)",
      "Bash(aws * discover-* *)",
      "Bash(aws * filter-* *)",
      "Bash(aws * get-* *)",
      "Bash(aws * head-* *)",
      "Bash(aws * list-* *)",
      "Bash(aws * lookup-* *)",
      "Bash(aws * query *)",
      "Bash(aws * retrieve-* *)",
      "Bash(aws * scan *)",
      "Bash(aws * search-* *)",
      "Bash(aws * tail *)",
      "Bash(aws * transact-get-* *)",
      "Bash(aws logs start-query *)",
      "Bash(basename *)",
      "Bash(cargo add *)",
      "Bash(cargo bench *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo deny *)",
      "Bash(cargo doc *)",
      "Bash(cargo fmt *)",
      "Bash(cargo init *)",
      "Bash(cargo install *)",
      "Bash(cargo nextest *)",
      "Bash(cargo remove *)",
      "Bash(cargo run *)",
      "Bash(cargo test *)",
      "Bash(cargo tree *)",
      "Bash(cargo update *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(curl *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dig *)",
      "Bash(dirname *)",
      "Bash(docker build *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh api *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh label list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr create *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr list *)",
      "Bash(gh pr merge --auto --squash)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh search *)",
      "Bash(ghq *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(gws calendar events list *)",
      "Bash(gws drive files export *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mise *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(npm ci *)",
      "Bash(npm install *)",
      "Bash(npm list *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm run type-check *)",
      "Bash(npm test *)",
      "Bash(nvim *)",
      "Bash(paplay *)",
      "Bash(pinact *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm run build *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run test *)",
      "Bash(pnpm run type-check *)",
      "Bash(pnpm test *)",
      "Bash(pwd)",
      "Bash(read *)",
      "Bash(readlink *)",
      "Bash(rtk *)",
      "Bash(sam validate *)",
      "Bash(sleep *)",
      "Bash(sort *)",
      "Bash(split *)",
      "Bash(stat *)",
      "Bash(stylua *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tmux *)",
      "Bash(tree *)",
      "Bash(uname *)",
      "Bash(uv add *)",
      "Bash(uv init *)",
      "Bash(uv pip list *)",
      "Bash(uv remove *)",
      "Bash(uv run mypy *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv sync *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs *)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "mcp__aws-knowledge__*",
      "mcp__claude_ai_Atlassian__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Slack__slack_read_*",
      "mcp__claude_ai_Slack__slack_search_*",
      "mcp__claude_ai_Slack__slack_send_message_draft",
      "mcp__playwright__*",
      "mcp__plugin_atlassian_atlassian__atlassianUserInfo",
      "mcp__plugin_atlassian_atlassian__get*",
      "mcp__plugin_atlassian_atlassian__lookup*",
      "mcp__plugin_atlassian_atlassian__search*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_serena_serena__*"
    ],
    "deny": [
      "Bash(gh api --method *)",
      "Bash(gh api * --method *)",
      "Bash(gh api -X *)",
      "Bash(gh api * -X *)",
      "Bash(gh api -f *)",
      "Bash(gh api * -f *)",
      "Bash(gh api -F *)",
      "Bash(gh api * -F *)",
      "Bash(gh api --raw-field *)",
      "Bash(gh api * --raw-field *)",
      "Bash(gh api --field *)",
      "Bash(gh api * --field *)",
      "Bash(gh api --input *)",
      "Bash(gh api * --input *)",
      "Bash(git push * main)",
      "Bash(git push * main *)",
      "Bash(git push * master)",
      "Bash(git push * master *)",
      "Bash(git push * develop)",
      "Bash(git push * develop *)",
      "Bash(git push * staging)",
      "Bash(git push * staging *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify processing"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ccjanus --flexible-match"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify permission"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify waiting_for_input"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify permission"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccargus-notify waiting_for_input"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "showTurnDuration": true
}
